{
  "name": "fingerprintjs-pro-react-native",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "description": "Official React Native client for Fingerprint. Best identification solution for React Native.",
  "scripts": {
    "prepare": "husky install",
    "build": "cd sdk && pnpm build",
    "build:sdk": "cd sdk && pnpm build:sdk",
    "build:plugin": "cd sdk && pnpm build:plugin",
    "lint": "eslint --ext .js,.ts,.jsx,.tsx --ignore-path .gitignore --max-warnings 0 .",
    "lint:fix": "pnpm lint --fix",
    "test": "cd sdk && pnpm test",
    "test:coverage": "cd sdk && pnpm test:coverage",
    "test:dts": "cd sdk && pnpm test:dts",
    "docs": "cd sdk && pnpm run docs",
    "changeset:version": "changeset version",
    "changeset:publish": "HUSKY=0 changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fingerprintjs/fingerprintjs-pro-react-native.git"
  },
  "author": "FingerprintJS, Inc (https://fingerprint.com)",
  "license": "MIT",
  "lint-staged": {
    "*.ts": "pnpm run lint:fix",
    "*.tsx": "pnpm run lint:fix",
    "*.js": "pnpm run lint:fix",
    "*.jsx": "pnpm run lint:fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/get-release-plan": "^4.0.16",
    "@changesets/types": "^6.1.0",
    "@commitlint/cli": "^17.1.2",
    "@fingerprintjs/changesets-changelog-format": "^0.2.0",
    "@fingerprintjs/commit-lint-dx-team": "^0.0.2",
    "@react-native/eslint-config": "0.76.6",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^5.36.2",
    "@typescript-eslint/parser": "^5.36.2",
    "eslint": "^8.23.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.0.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "prettier": "^2.6.2",
    "typescript": "5.0.4"
  }
}
